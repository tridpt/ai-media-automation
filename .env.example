# ===== AI models =====
OPENAI_API_KEY=sk-xxxx
ANTHROPIC_API_KEY=sk-ant-xxxx
# (Tuỳ chọn) Chỉ điền nếu dùng endpoint tương thích OpenAI khác chính thức.
# Để trống = dùng https://api.openai.com/v1
OPENAI_BASE_URL=
# (Tuỳ chọn) Model tạo ảnh: dall-e-3 (mặc định) hoặc gpt-image-1 (cần verify).
OPENAI_IMAGE_MODEL=dall-e-3
# (Tuỳ chọn) Model text-to-speech tạo audio MP3.
OPENAI_TTS_MODEL=gpt-4o-mini-tts

# ===== Google =====
# Đường dẫn tới file service account JSON
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
# ID của Google Sheet (lấy từ URL)
SHEET_ID=your_sheet_id_here
# Tên tab/sheet chứa task
SHEET_TAB=Sheet1
# ID folder Google Drive để lưu output
DRIVE_FOLDER_ID=your_drive_folder_id_here

# ===== Email (SMTP - ví dụ Gmail) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=notify_target@gmail.com
ADMIN_EMAIL=admin@gmail.com

# ===== Slack =====
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ===== Local =====
DB_PATH=automation.db
OUTPUT_DIR=outputs
